---
import Layout from "../layouts/Layout.astro";
import UserStoryViewer from "../components/UserStoryViewer.tsx";
import { loadAllUserStories } from "../lib/parse-user-stories";

const stories = loadAllUserStories();

const totalFeatures = stories.reduce((s, e) => s + e.features.length, 0);
---

<Layout title="User Stories" active="us">
  <h1 class="page-title">User Stories e Features</h1>
  <p class="page-subtitle">
    {stories.length} epicos, {totalFeatures} features — dados lidos de
    <code>docs/04_modules/user-stories/</code>
  </p>

  <UserStoryViewer stories={stories} client:load />
</Layout>
