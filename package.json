{
    "name": "@easycf/monorepo",
    "version": "0.8.0",
    "private": true,
    "description": "The Enterprise-Grade Agnostic Code Framework",
    "scripts": {
        "release": "node .agents/scripts/release.mjs patch",
        "release:minor": "node .agents/scripts/release.mjs minor",
        "release:major": "node .agents/scripts/release.mjs major",
        "commit": "node .agents/scripts/git-semantic-commit.js",
        "sync:private": "powershell .agents/scripts/git-sync-private.ps1",
        "sync:public": "powershell .agents/scripts/git-sync-public.ps1",
        "lint:docs": "node .agents/scripts/lint-docs.js",
        "lint:markdown": "markdownlint-cli2 \"**/*.md\" \"#**/node_modules\" \"#.gemini/**\" \"#tmp/**\"",
        "validate:manifests": "node .agents/scripts/validate-manifests.js",
        "qa:all": "npm run lint:docs && npm run lint:markdown && npm run validate:manifests"
    },
    "devDependencies": {
        "ajv": "^8.18.0",
        "js-yaml": "^4.1.1",
        "markdownlint-cli2": "^0.21.0",
        "typescript": "^5.4.0"
    },
    "packageManager": "pnpm@9.0.0",
    "engines": {
        "node": ">=20.0.0"
    }
}
