  },
  "constraints": {
    "temporal": {
      "description": "Regras de integridade temporal — MUST ser validadas antes de gravar",
      "rules": [
        "codegen.completed_at MUST be after codegen.started_at (or null)",
        "Each agents.{id}.completed_at MUST be after codegen.started_at",
        "promotion.completed_at MUST be after codegen.completed_at (if both exist)",
        "validations.last_run MUST be after codegen.completed_at (if both exist)"
      ]
    },
    "promotion_gate": {
      "description": "Promoção só é permitida se validations.verdict.ready_for_promotion === true",
      "rule": "promote-module MUST check validations.verdict.ready_for_promotion before proceeding"
    },
    "required_sections": {
      "description": "Seções obrigatórias após codegen completo",
      "after_codegen": ["codegen", "validations"],
      "after_promotion": ["codegen", "validations", "promotion"]
    }
  },
  "file_naming": "MOD-{NNN}.json (ex: MOD-000.json, MOD-001.json)",
  "location": ".agents/execution-state/"
}
