{
  "permissions": {
    "allow": [
      "Skill(ralph-wiggum:ralph-loop)",
      "Bash(pnpm run qa:*)",
      "Bash(pnpm run lint:*)",
      "Bash(pnpm run validate:*)",
      "Bash(node .agents/scripts/*)",
      "Bash(for mod:*)",
      "Bash(do echo:*)",
      "Bash(sed 's/\\\\.yaml.*//')",
      "Bash(sed 's/\\\\..*//')",
      "Bash(node:*)",
      "Bash(ls -d D:/Dev/EasyCodeFramework/docs/04_modules/mod-0*)",
      "Bash(find /d/Dev/EasyCodeFramework -path */template* -o -path */_template*)",
      "Bash(find /d/Dev/EasyCodeFramework/.agents -type f \\\\\\(-name *.js -o -name *.mjs \\\\\\))",
      "Bash(ls:*)",
      "Bash(npx pnpm:*)",
      "Bash(npx markdownlint-cli2:*)",
      "Bash(done)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{const j=JSON.parse(d);const f=j.tool_input?.file_path||'';if(/pen-.*-pendente\\.md$/.test(f)){process.stdout.write(f)}else{process.exit(0)}})\" | { read -r f; if [ -n \"$f\" ]; then npx markdownlint-cli2 \"$f\" 2>&1 || true; fi; }",
            "timeout": 30,
            "statusMessage": "Validando markdown do arquivo de pendências..."
          }
        ]
      }
    ]
  }
}
