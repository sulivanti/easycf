{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://easy-a2.dev/schemas/screen-manifest.v1.schema.json",
    "title": "Screen Manifest v1",
    "description": "Schema alinhado com screen-manifest.schema.v1.yaml (DOC-UX-010 §Manifestos de Infra/Shell)",
    "type": "object",
    "required": [
        "schema_version",
        "screen_id",
        "name",
        "type",
        "module",
        "route",
        "auth_required",
        "linked_stories",
        "telemetry_defaults",
        "actions"
    ],
    "additionalProperties": false,
    "properties": {
        "schema_version": {
            "type": "string",
            "enum": ["v1"],
            "description": "Versão do schema. Obrigatório para versionamento futuro."
        },
        "screen_id": {
            "type": "string",
            "pattern": "^UX-[A-Z]{2,8}-[0-9]{3}$",
            "description": "Identificador único e estável da tela. Ex: UX-AUTH-001, UX-SHELL-001."
        },
        "name": {
            "type": "string",
            "minLength": 2
        },
        "type": {
            "type": "string",
            "enum": [
                "auth",
                "shell",
                "dashboard",
                "list",
                "form",
                "detail",
                "config",
                "monitor",
                "inbox"
            ],
            "description": "Tipo de tela. Define o template de layout padrão."
        },
        "module": {
            "type": "string",
            "pattern": "^MOD-[0-9]{3}$",
            "description": "Módulo ECF responsável por esta tela. Ex: MOD-001."
        },
        "route": {
            "type": "string",
            "minLength": 1,
            "description": "Rota frontend associada. Ex: /login, /dashboard, /* (layout wrapper)."
        },
        "auth_required": {
            "type": "boolean",
            "description": "Se true, JWT válido é exigido para renderizar a tela."
        },
        "pre_auth": {
            "type": "boolean",
            "default": false,
            "description": "Se true, ações desta tela NÃO incluem tenant_id no UIActionEnvelope (fase pré-autenticação)."
        },
        "layout": {
            "type": "string",
            "enum": ["centered", "shell", "fullscreen", "split"],
            "default": "shell",
            "description": "Template de layout: centered, shell, fullscreen ou split."
        },
        "linked_stories": {
            "type": "array",
            "items": {
                "type": "string",
                "pattern": "^US-MOD-[0-9]{3}(-F[0-9]{2})?$",
                "description": "Ex: US-MOD-001, US-MOD-001-F01"
            },
            "minItems": 1,
            "uniqueItems": true,
            "description": "Lista de User Stories que governam esta tela. Obrigatório ao menos o épico pai."
        },
        "telemetry_defaults": {
            "$ref": "#/$defs/telemetry_defaults"
        },
        "panels": {
            "type": "array",
            "items": {
                "$ref": "#/$defs/panel"
            },
            "description": "Sub-painéis ou contextos dentro de uma mesma rota (sem reload de página)."
        },
        "actions": {
            "type": "array",
            "minItems": 1,
            "items": {
                "$ref": "#/$defs/action_entry"
            }
        },
        "components": {
            "type": "array",
            "items": {
                "$ref": "#/$defs/component"
            },
            "description": "Componentes de UI que compõem a tela."
        },
        "navigation": {
            "$ref": "#/$defs/navigation",
            "description": "Regras de navegação e proteção de rota."
        },
        "sidebar_menu": {
            "$ref": "#/$defs/sidebar_menu",
            "description": "Estrutura do menu lateral (usado em manifests do tipo shell)."
        },
        "module_shortcuts_catalog": {
            "type": "array",
            "items": {
                "$ref": "#/$defs/module_shortcut"
            },
            "description": "Catálogo de atalhos de módulo (usado em manifests do tipo dashboard)."
        },
        "notes": {
            "type": "string",
            "description": "Observações e decisões de design relevantes para o time."
        },
        "changelog": {
            "type": "array",
            "items": {
                "$ref": "#/$defs/changelog_entry"
            }
        }
    },
    "$defs": {
        "telemetry_defaults": {
            "type": "object",
            "required": [
                "package",
                "include_tenant_id",
                "propagate_correlation_id",
                "capture_duration_ms"
            ],
            "additionalProperties": false,
            "properties": {
                "package": {
                    "type": "string",
                    "default": "@easycf/ui-telemetry"
                },
                "include_tenant_id": {
                    "type": "boolean",
                    "description": "false em telas pre_auth=true."
                },
                "propagate_correlation_id": {
                    "type": "boolean",
                    "default": true
                },
                "capture_duration_ms": {
                    "type": "boolean",
                    "default": true
                }
            }
        },
        "action_entry": {
            "type": "object",
            "required": [
                "id",
                "label",
                "type"
            ],
            "additionalProperties": false,
            "properties": {
                "id": {
                    "type": "string",
                    "pattern": "^[a-z_]+$",
                    "description": "Identificador único da ação dentro do manifest. Ex: submit_login."
                },
                "label": {
                    "type": "string",
                    "description": "Rótulo legível da ação para documentação."
                },
                "type": {
                    "type": "string",
                    "enum": ["view", "submit", "navigate", "client_only"],
                    "description": "Tipo de ação: view, submit, navigate ou client_only."
                },
                "operation_id": {
                    "type": ["string", "null"],
                    "description": "operationId do OpenAPI associado. Obrigatório quando type != client_only."
                },
                "http_method": {
                    "type": ["string", "null"],
                    "enum": ["GET", "POST", "PUT", "PATCH", "DELETE", null],
                    "description": "Método HTTP da operação. Obrigatório quando type != client_only."
                },
                "endpoint": {
                    "type": ["string", "null"],
                    "description": "Path da API. Ex: /api/v1/auth/login. Obrigatório quando type != client_only."
                },
                "client_only": {
                    "type": "boolean",
                    "default": false,
                    "description": "Se true, nenhuma requisição HTTP é feita."
                },
                "requires_scope": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "description": "Escopos RBAC necessários para executar a ação."
                },
                "loading_state": {
                    "type": "string",
                    "enum": ["button", "skeleton", "overlay", "none"],
                    "default": "none",
                    "description": "Tipo de feedback de loading durante execução."
                },
                "error_handling": {
                    "$ref": "#/$defs/error_handling"
                },
                "telemetry_override": {
                    "$ref": "#/$defs/telemetry_override"
                },
                "notes": {
                    "type": "string",
                    "description": "Observações específicas da ação."
                }
            },
            "allOf": [
                {
                    "if": {
                        "properties": {
                            "client_only": {
                                "const": true
                            }
                        },
                        "required": ["client_only"]
                    },
                    "then": {},
                    "else": {
                        "if": {
                            "properties": {
                                "type": {
                                    "enum": ["view", "submit"]
                                }
                            }
                        },
                        "then": {
                            "required": ["operation_id", "http_method", "endpoint"]
                        }
                    }
                }
            ]
        },
        "error_handling": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "strategy": {
                    "type": "string",
                    "enum": ["toast", "inline", "redirect", "silent"],
                    "description": "Estratégia de tratamento de erro visual."
                },
                "include_correlation_id": {
                    "type": "boolean",
                    "default": true
                },
                "user_message": {
                    "type": "string",
                    "description": "Mensagem amigável exibida ao usuário. Não expõe detalhes técnicos."
                },
                "enumeration_safe": {
                    "type": "boolean",
                    "default": false,
                    "description": "Se true, mensagem é genérica para prevenir user enumeration."
                }
            }
        },
        "telemetry_override": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "include_tenant_id": {
                    "type": "boolean"
                },
                "capture_duration_ms": {
                    "type": "boolean"
                }
            }
        },
        "panel": {
            "type": "object",
            "required": ["id", "label"],
            "additionalProperties": false,
            "properties": {
                "id": {
                    "type": "string"
                },
                "label": {
                    "type": "string"
                },
                "default": {
                    "type": "boolean"
                },
                "actions_scope": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "component": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "id": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                },
                "description": {
                    "type": "string"
                },
                "conditional": {
                    "type": "string",
                    "description": "Condição de renderização. Ex: 'panel == login'"
                },
                "actions_used": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "description": "IDs das actions que este componente dispara."
                }
            }
        },
        "navigation": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "guard": {
                    "type": "string",
                    "enum": ["auth", "guest", "none"],
                    "description": "auth = rota protegida; guest = apenas não-autenticados; none = pública."
                },
                "redirect_if_auth": {
                    "type": ["string", "null"],
                    "description": "Redireciona para esta rota se usuário já estiver autenticado."
                },
                "redirect_if_unauth": {
                    "type": ["string", "null"],
                    "description": "Redireciona para esta rota se usuário não estiver autenticado."
                },
                "back_action": {
                    "type": "string",
                    "description": "Rota de retorno padrão."
                }
            }
        },
        "sidebar_menu": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "groups": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/sidebar_menu_group"
                    }
                }
            }
        },
        "sidebar_menu_group": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "id": {
                    "type": "string"
                },
                "label": {
                    "type": "string"
                },
                "icon": {
                    "type": "string"
                },
                "items": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/sidebar_menu_item"
                    }
                }
            }
        },
        "sidebar_menu_item": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "id": {
                    "type": "string"
                },
                "label": {
                    "type": "string"
                },
                "icon": {
                    "type": "string"
                },
                "route": {
                    "type": "string"
                },
                "required_scope": {
                    "type": "string"
                },
                "active_match": {
                    "type": "string"
                },
                "children": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/sidebar_menu_item"
                    }
                }
            }
        },
        "module_shortcut": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
                "id": {
                    "type": "string"
                },
                "label": {
                    "type": "string"
                },
                "icon": {
                    "type": "string"
                },
                "route": {
                    "type": "string"
                },
                "requires_scope": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "description": {
                    "type": "string"
                }
            }
        },
        "changelog_entry": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "version": {
                    "type": "string"
                },
                "date": {
                    "type": "string"
                },
                "author": {
                    "type": "string"
                },
                "description": {
                    "type": "string"
                }
            }
        }
    }
}
