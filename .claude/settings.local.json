          {
            "type": "command",
            "command": "node -e \"let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{const j=JSON.parse(d);const f=j.tool_input?.file_path||'';if(/pen-.*-pendente\\.md$/.test(f)){process.stdout.write(f)}else{process.exit(0)}})\" | { read -r f; if [ -n \"$f\" ]; then npx markdownlint-cli2 \"$f\" 2>&1 || true; fi; }",
            "timeout": 30,
            "statusMessage": "Validando markdown do arquivo de pendências..."
          }
        ]
      }
    ]
