# Configurações do Projeto
PROJECT_NAME=easya1
COMPOSE_PROJECT_NAME=easya1

# Banco de Dados (PostgreSQL)
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=easya1

# Aplicação
API_PORT=3000
API_BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Segurança
JWT_SECRET=

# E-mail (Resend)
# Obtenha sua chave em https://resend.com
RESEND_API_KEY=
# Branding
# Configurações de identidade visual para e-mails e UI
BRAND_NAME=EasyA1
BRAND_PRIMARY_COLOR=#1A56DB

# String de conexão para o Drizzle ORM
# Formato: postgresql://[user]:[password]@[host]:[port]/[db_name]
DATABASE_URL=postgresql://admin:admin@localhost:5432/easya1

# Google SSO (INT-000-01)
SSO_GOOGLE_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URI=http://localhost:3000/api/v1/auth/google/callback

# Microsoft SSO (INT-000-02)
SSO_MICROSOFT_ENABLED=false
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
MICROSOFT_CALLBACK_URI=http://localhost:3000/api/v1/auth/microsoft/callback

# Registration
PUBLIC_REGISTRATION_ENABLED=true
