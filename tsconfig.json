{
  "$schema": "https://json.schemastore.org/tsconfig",
  "_comment": "tsconfig BASE do monorepo — não compila nada. Cada workspace herda via 'extends'.",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  }
}