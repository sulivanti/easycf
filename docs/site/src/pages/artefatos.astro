---
import Layout from "../layouts/Layout.astro";
import fs from "node:fs";
import path from "node:path";

const DOCS_ROOT = path.resolve(import.meta.dirname ?? ".", "../../../");

// Read INDEX.md and parse the normative documents table
function parseIndexMd(): Array<{ name: string; id: string; version: string; status: string; desc: string; path: string }> {
  const indexPath = path.join(DOCS_ROOT, "INDEX.md");
  if (!fs.existsSync(indexPath)) return [];

  const content = fs.readFileSync(indexPath, "utf-8");
  const docs: Array<{ name: string; id: string; version: string; status: string; desc: string; path: string }> = [];

  // Match table rows with links: | [Name](path) | ID | Version | Status | Desc |
  const re = /\|\s*\[([^\]]+)\]\(([^)]+)\)\s*\|\s*([^|]+)\|\s*([^|]+)\|\s*([^|]+)\|\s*([^|]+)\|/g;
  let m: RegExpExecArray | null;
  while ((m = re.exec(content)) !== null) {
    docs.push({
      name: m[1].trim(),
      path: m[2].trim(),
      id: m[3].trim(),
      version: m[4].trim(),
      status: m[5].trim(),
      desc: m[6].trim(),
    });
  }
  return docs;
}

const normDocs = parseIndexMd();

// Categorize
const categories = [
  { label: "Normativos Canonicos", docs: normDocs.filter((d) => d.id.startsWith("DOC-DEV") || d.id.startsWith("DOC-GNP") || d.id.startsWith("DOC-GPA") || d.id.startsWith("DOC-ESC")) },
  { label: "Arquitetura", docs: normDocs.filter((d) => d.id.startsWith("DOC-ARC")) },
  { label: "Infraestrutura e Padroes", docs: normDocs.filter((d) => d.id.startsWith("DOC-PADRAO")) },
  { label: "UX e Interface", docs: normDocs.filter((d) => d.id.startsWith("DOC-UX")) },
  { label: "Foundation", docs: normDocs.filter((d) => d.id.startsWith("DOC-FND")) },
];

function statusBadge(status: string): string {
  const s = status.trim().toUpperCase();
  if (s === "ACTIVE") return "badge badge-ready";
  if (s === "READY") return "badge badge-approved";
  if (s === "DRAFT") return "badge badge-draft";
  return "badge badge-muted";
}
---

<Layout title="Artefatos" active="artefatos">
  <h1 class="page-title">Artefatos e Normativos</h1>
  <p class="page-subtitle">
    {normDocs.length} documentos normativos — indice lido de <code>docs/INDEX.md</code>
  </p>

  {categories.filter((c) => c.docs.length > 0).map((cat) => (
    <div class="section">
      <div class="card-header">{cat.label}</div>
      <div class="card">
        <table class="data-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Documento</th>
              <th>Versao</th>
              <th>Status</th>
              <th>Descricao</th>
            </tr>
          </thead>
          <tbody>
            {cat.docs.map((doc) => (
              <tr>
                <td class="mono" style="font-weight: 600; font-size: 11px; white-space: nowrap;">
                  {doc.id}
                </td>
                <td style="font-size: 12px;">{doc.name}</td>
                <td class="mono" style="font-size: 11px; text-align: center;">{doc.version}</td>
                <td>
                  <span class={statusBadge(doc.status)}>{doc.status}</span>
                </td>
                <td style="font-size: 11px; color: var(--text-secondary);">{doc.desc}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  ))}
</Layout>
