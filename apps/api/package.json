{
  "name": "@easycode/api",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm",
    "test": "vitest",
    "lint": "eslint src/ test/",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx db/seed-admin.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^9.0.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/helmet": "^11.0.0",
    "@fastify/jwt": "^8.0.0",
    "@fastify/oauth2": "^7.0.0",
    "@fastify/rate-limit": "^9.0.0",
    "bcrypt": "^5.1.0",
    "drizzle-orm": "^0.45.0",
    "drizzle-zod": "^0.8.0",
    "fastify": "^4.29.0",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "2",
    "ioredis": "^5.4.0",
    "otplib": "^12.0.0",
    "postgres": "^3.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/node": "^20.0.0",
    "drizzle-kit": "^0.31.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
