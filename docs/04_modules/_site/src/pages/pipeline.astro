---
import Layout from "../layouts/Layout.astro";
import PipelineMatrix from "../components/PipelineMatrix.tsx";
import { loadAllModules } from "../lib/parse-modules";
import { PHASES } from "../lib/types";

const modules = loadAllModules();

// Summary per phase
const phaseSummary = PHASES.map((p) => ({
  ...p,
  done: modules.filter((m) => m.phase > p.id).length,
  current: modules.filter((m) => m.phase === p.id).length,
  pending: modules.filter((m) => m.phase < p.id).length,
}));
---

<Layout title="Pipeline" active="pipeline">
  <h1 class="page-title">Pipeline XP</h1>
  <p class="page-subtitle">
    Matriz de 12 modulos x 6 fases — progresso em tempo de build
  </p>

  <!-- Phase summary cards -->
  <div class="stat-grid" style="margin-bottom: 32px;">
    {phaseSummary.map((p) => (
      <div class="stat-card">
        <div style="font-size: 20px; margin-bottom: 4px;">{p.icon}</div>
        <div style="font-size: 13px; font-weight: 600; margin-bottom: 8px;">{p.label}</div>
        <div style="display: flex; justify-content: center; gap: 12px; font-size: 11px;">
          <span style="color: var(--ready);">{p.done} ✓</span>
          <span style="color: var(--draft);">{p.current} ●</span>
          <span style="color: var(--text-muted);">{p.pending} ○</span>
        </div>
      </div>
    ))}
  </div>

  <!-- Pipeline Matrix -->
  <div class="card section">
    <PipelineMatrix modules={modules} client:load />
  </div>

  <!-- Legend -->
  <div style="display: flex; gap: 24px; font-size: 12px; color: var(--text-secondary); margin-top: 8px;">
    <span><span style="color: var(--ready);">✓</span> Concluida</span>
    <span><span style="color: var(--draft);">●</span> Fase atual</span>
    <span><span style="color: var(--text-muted);">○</span> Pendente</span>
  </div>
</Layout>
