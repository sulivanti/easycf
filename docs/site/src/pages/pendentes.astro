---
import Layout from "../layouts/Layout.astro";
import PlanoAcaoViewer from "../components/PlanoAcaoViewer.tsx";
import { loadAllPendentesDetailed } from "../lib/parse-pendentes-full";
import { loadAllModules } from "../lib/parse-modules";

const penModules = loadAllPendentesDetailed();
const modules = loadAllModules();
const allPendentes = modules.flatMap((m) => m.pendentes);

const totalPen = penModules.reduce((s, m) => s + m.pendentes.length, 0);
const totalOpen = allPendentes.filter((p) => p.status === "ABERTA").length;

// Severity distribution
const sevDist = {
  bloq: allPendentes.filter((p) => p.severidade.toUpperCase() === "BLOQ").length,
  alta: allPendentes.filter((p) => p.severidade.toUpperCase() === "ALTA").length,
  media: allPendentes.filter((p) => ["MEDIA", "MÉDIA"].includes(p.severidade.toUpperCase())).length,
  baixa: allPendentes.filter((p) => p.severidade.toUpperCase() === "BAIXA").length,
};

const codegenReady = modules.filter((m) => m.estado === "READY" && m.codegen === "NAO INICIADO");
const promoteReady = modules.filter((m) => m.estado === "DRAFT" && m.phase >= 4);
---

<Layout title="Pendencias" active="pendentes">
  <h1 class="page-title">Pendencias</h1>
  <p class="page-subtitle">
    {totalPen} pendencias em {penModules.length} modulos — {totalOpen} abertas
  </p>

  <!-- Severity summary -->
  <div class="stat-grid">
    <div class="stat-card">
      <div class="stat-value" style="color: var(--text-primary)">{totalPen}</div>
      <div class="stat-label">Total</div>
    </div>
    <div class="stat-card">
      <div class="stat-value" style="color: var(--danger)">{totalOpen}</div>
      <div class="stat-label">Abertas</div>
    </div>
    <div class="stat-card">
      <div class="stat-value" style="color: var(--sev-bloq)">{sevDist.bloq}</div>
      <div class="stat-label">Bloqueantes</div>
    </div>
    <div class="stat-card">
      <div class="stat-value" style="color: var(--sev-alta)">{sevDist.alta}</div>
      <div class="stat-label">Alta</div>
    </div>
    <div class="stat-card">
      <div class="stat-value" style="color: var(--sev-media)">{sevDist.media}</div>
      <div class="stat-label">Media</div>
    </div>
    <div class="stat-card">
      <div class="stat-value" style="color: var(--sev-baixa)">{sevDist.baixa}</div>
      <div class="stat-label">Baixa</div>
    </div>
  </div>

  <!-- Plano de Acao viewer (Resumo + Pendencias + Checklist) -->
  <PlanoAcaoViewer modules={penModules} client:load />

  <!-- Quick actions from modules -->
  {(codegenReady.length > 0 || promoteReady.length > 0) && (
    <div class="section" style="margin-top: 36px;">
      <div class="card-header">Proximos Passos</div>

      {codegenReady.length > 0 && (
        <div class="card" style="margin-bottom: 10px; border-left: 3px solid var(--ready); padding: 14px 16px;">
          <div style="font-size: 13px; font-weight: 700; margin-bottom: 8px; color: var(--ready-fg);">
            {codegenReady.length} modulos aguardando Codegen
          </div>
          {codegenReady.map((mod) => (
            <div style="display: flex; align-items: center; gap: 12px; padding: 5px 0; border-bottom: 1px solid var(--border-subtle);">
              <span class="mono" style="font-weight: 700; font-size: 11px; min-width: 70px; color: var(--text-primary);">{mod.id}</span>
              <span style="font-size: 12px; color: var(--text-secondary); flex: 1;">{mod.name}</span>
              <div class="cmd-box" style="padding: 4px 8px; font-size: 10px;">
                <span class="cmd-prefix">$</span>
                <span class="cmd-text">{mod.nextCmd}</span>
              </div>
            </div>
          ))}
        </div>
      )}

      {promoteReady.length > 0 && (
        <div class="card" style="margin-bottom: 10px; border-left: 3px solid var(--draft); padding: 14px 16px;">
          <div style="font-size: 13px; font-weight: 700; margin-bottom: 8px; color: var(--draft-fg);">
            {promoteReady.length} modulos aguardando Promocao
          </div>
          {promoteReady.map((mod) => (
            <div style="display: flex; align-items: center; gap: 12px; padding: 5px 0; border-bottom: 1px solid var(--border-subtle);">
              <span class="mono" style="font-weight: 700; font-size: 11px; min-width: 70px; color: var(--text-primary);">{mod.id}</span>
              <span style="font-size: 12px; color: var(--text-secondary); flex: 1;">{mod.name}</span>
              <div class="cmd-box" style="padding: 4px 8px; font-size: 10px;">
                <span class="cmd-prefix">$</span>
                <span class="cmd-text">{mod.nextCmd}</span>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  )}
</Layout>
