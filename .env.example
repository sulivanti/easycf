# =============================================================================
# .env.example — EasyCodeFramework
# =============================================================================
# INSTRUÇÕES:
#   1. Copie este arquivo: `cp .env.example .env`
#   2. Preencha os valores marcados com <PREENCHER> antes de subir a aplicação.
#   3. NUNCA commite o arquivo .env com segredos reais.
#   4. A cada nova variável adicionada ao .env, atualize ESTE arquivo.
# Referência: docs/01_normativos/DOC-PADRAO-004_Variaveis_de_Ambiente.md
# =============================================================================

# -----------------------------------------------------------------------------
# [PROJETO] Identidade e Ambiente
# -----------------------------------------------------------------------------
NODE_ENV=development
PROJECT_NAME=nome
COMPOSE_PROJECT_NAME=nome

# -----------------------------------------------------------------------------
# [APLICAÇÃO] API e Frontend
# -----------------------------------------------------------------------------
API_PORT=3000
API_BASE_URL=http://localhost:3000

# URL pública do frontend — usada em redirects, emails e cookies de CORS
FRONTEND_URL=http://localhost:5173

# Origens permitidas pelo CORS (separadas por vírgula se múltiplas)
CORS_ORIGIN=http://localhost:5173

# Nível de log: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# [BANCO DE DADOS] PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=admin
POSTGRES_PASSWORD=<PREENCHER>
POSTGRES_DB=meu_banco

# String de conexão usada pelo Drizzle ORM
# Formato: postgresql://[user]:[password]@[host]:[port]/[db_name]
DATABASE_URL=postgresql://admin:<PREENCHER>@localhost:5432/meu_banco

# -----------------------------------------------------------------------------
# [CACHE / FILA] Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# [SEGURANÇA] JWT e Criptografia
# -----------------------------------------------------------------------------
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Mínimo: 32 caracteres
JWT_SECRET=<PREENCHER-min-32-chars>

# Duração do token de acesso (ex: 15m, 1h, 7d)
JWT_EXPIRES_IN=15m

# Duração do refresh token
JWT_REFRESH_EXPIRES_IN=7d

# Tempo máximo de inatividade antes de encerrar sessão (ms) — usado pelo frontend
# Padrão: 1800000 (30 minutos)
VITE_SESSION_IDLE_TIMEOUT_MS=1800000

# -----------------------------------------------------------------------------
# [E-MAIL] Resend
# Obtenha sua chave em: https://resend.com/api-keys
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Endereço remetente padrão
MAIL_FROM=noreply@seudominio.com

# -----------------------------------------------------------------------------
# [BRANDING] Identidade Visual (e-mails e UI)
# -----------------------------------------------------------------------------
BRAND_NAME=MeuProjeto
BRAND_PRIMARY_COLOR=#1A56DB

# -----------------------------------------------------------------------------
# [SSO] Google (INT-000-01)
# Docs: https://console.cloud.google.com/apis/credentials
# -----------------------------------------------------------------------------
SSO_GOOGLE_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URI=http://localhost:3000/api/v1/auth/google/callback

# -----------------------------------------------------------------------------
# [SSO] Microsoft / Azure AD (INT-000-02)
# Docs: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
# -----------------------------------------------------------------------------
SSO_MICROSOFT_ENABLED=false
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
MICROSOFT_CALLBACK_URI=http://localhost:3000/api/v1/auth/microsoft/callback

# -----------------------------------------------------------------------------
# [SSO] Apple (Sign in with Apple) (INT-000-06)
# Docs: https://developer.apple.com/sign-in-with-apple/get-started/
# -----------------------------------------------------------------------------
SSO_APPLE_ENABLED=false
APPLE_TEAM_ID=
APPLE_CLIENT_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_REDIRECT_URI=http://localhost:3000/api/v1/auth/apple/callback

# -----------------------------------------------------------------------------
# [ACESSO] Registro público de usuários
# -----------------------------------------------------------------------------
PUBLIC_REGISTRATION_ENABLED=true
